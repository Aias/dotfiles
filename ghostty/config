# Ghostty terminal configuration
# Run `ghostty +show-config --default --docs` for all options and defaults,
# or see https://ghostty.org/docs/config.

shell-integration = zsh
window-padding-x = 12
window-padding-y = 12
window-width = 125
window-height = 35
window-padding-balance = true
window-colorspace = display-p3
background-opacity = 0.9
background-blur = 30
background = #1B1D21
foreground = #E8EAED
font-family = Berkeley Mono Variable
font-variation = wdth=88
adjust-cell-height = 10%
keybind = shift+enter=text:\n
link-url = true
unfocused-split-opacity = 0.9
unfocused-split-fill = #3D2B1F
# window-decoration = none
window-save-state = always
